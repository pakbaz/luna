<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:MoonSimulation.Views"
             x:Class="MoonSimulation.MainPage"
             BackgroundColor="#0a0a2e"
             Title="Luna 🌙">

    <Grid RowDefinitions="3*, 4*, Auto"
          Padding="0"
          RowSpacing="0">

        <!-- Top: Orbital View (Sun-Earth-Moon with day/night) -->
        <Border Grid.Row="0"
                StrokeThickness="0"
                Margin="8,8,8,4">
            <views:OrbitalView x:Name="OrbitalCanvas"
                               EnableTouchEvents="False" />
        </Border>

        <!-- Middle: Moon Phase (left) + Earth Sky View (right) -->
        <Grid Grid.Row="1"
              ColumnDefinitions="*, *"
              ColumnSpacing="4"
              Margin="8,4,8,4">

            <!-- Moon Phase Close-up -->
            <Border Grid.Column="0"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 8">
                <views:MoonPhaseView x:Name="PhaseCanvas"
                                     EnableTouchEvents="False" />
            </Border>

            <!-- Earth Sky View (Day/Night from observer) -->
            <Border Grid.Column="1"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 8">
                <views:EarthSkyView x:Name="SkyCanvas"
                                    EnableTouchEvents="False" />
            </Border>
        </Grid>

        <!-- Controls Bar — Big, Colorful, Kid-Friendly -->
        <Grid Grid.Row="2"
              ColumnDefinitions="Auto, *, Auto"
              Padding="20,10,20,18"
              ColumnSpacing="16"
              BackgroundColor="#12123a">

            <!-- Play/Pause Button (BIG) -->
            <Button x:Name="PlayPauseBtn"
                    Grid.Column="0"
                    Text="⏸️"
                    FontSize="32"
                    WidthRequest="70"
                    HeightRequest="70"
                    CornerRadius="35"
                    BackgroundColor="#3a3a8a"
                    TextColor="White"
                    BorderWidth="2"
                    BorderColor="#6060cc"
                    Clicked="OnPlayPauseClicked" />

            <!-- Speed Slider with fun labels -->
            <Grid Grid.Column="1"
                  RowDefinitions="Auto, Auto, Auto"
                  RowSpacing="2">

                <Grid ColumnDefinitions="Auto, *, Auto"
                      Grid.Row="0">
                    <Label Grid.Column="0"
                           Text="🐢"
                           FontSize="24"
                           VerticalOptions="Center" />
                    <Slider x:Name="SpeedSlider"
                            Grid.Column="1"
                            Minimum="0.1"
                            Maximum="10"
                            Value="1"
                            MinimumTrackColor="#7070dd"
                            MaximumTrackColor="#2a2a4a"
                            ThumbColor="#b0b0ff"
                            ValueChanged="OnSpeedChanged" />
                    <Label Grid.Column="2"
                           Text="🐇"
                           FontSize="24"
                           VerticalOptions="Center" />
                </Grid>

                <!-- Phase Label (big, fun) -->
                <Label x:Name="PhaseLabel"
                       Grid.Row="1"
                       Text="🌑  Moon is Hiding!"
                       FontSize="20"
                       TextColor="#f0e0ff"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center" />

                <!-- Time of Day Label -->
                <Label x:Name="TimeLabel"
                       Grid.Row="2"
                       Text="☀️ Day  12:00"
                       FontSize="16"
                       TextColor="#c0c0e0"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center" />
            </Grid>

            <!-- Speed display -->
            <StackLayout Grid.Column="2"
                         VerticalOptions="Center"
                         Spacing="2">
                <Label x:Name="SpeedLabel"
                       Text="1.0x"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="#9090cc"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center" />
                <Label Text="speed"
                       FontSize="11"
                       TextColor="#606080"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center" />
            </StackLayout>
        </Grid>
    </Grid>
</ContentPage>
